# ─── LLM Keys (at least one is required for AI-powered policies) ─────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── DLP / PII Detection (optional) ─────────────────────────────────
# Default engine is "nerpa". Set to "aws" to use AWS Comprehend instead.
# DEFAULT_DLP_ENGINE=nerpa
# NERPA_BASE_URL=http://localhost:8100

# ─── AWS (optional — needed for Textract OCR and Comprehend PII) ─────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Optional overrides (defaults work out of the box with docker compose) ───
# SECRET_KEY=change-me-in-production
# DEBUG=false
# FRONTEND_URL=http://localhost:8000
# API_TOKEN_PREFIX=ovr_core_

# ─── Anonymous usage telemetry ───────────────────────────────────────────────
# Overmind sends anonymous aggregate usage statistics (feature-usage boolean
# flags and a scale bucket) to PostHog so we can understand adoption and
# prioritise development. No trace content, prompts, user emails, or PII is
# ever collected. See docs/prd/telemetry.md for the exact payload.
# Uncomment the line below to opt out entirely.
# OVERMIND_ANALYTICS_ENABLED=false
